    },
    {
      "cell_type": "code",
      "source": [
        "embeddings = model.encode(sentences)"
      ],
      "metadata": {
        "id": "gGgFd0ZdGx4l"
      },
      "execution_count": 17,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "similarity_matrix = cosine_similarity(embeddings)\n",
        "\n",
        "df = pd.DataFrame(similarity_matrix)\n",
        "\n",
        "plt.figure(figsize=(8,6))\n",
        "sns.heatmap(df, annot=True, cmap=\"coolwarm\")\n",
        "plt.title(\"Sentence Similarity Matrix\")\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 545
        },
        "id": "5TOozPCQHcGH",
        "outputId": "5475eaa7-a65c-4b48-c211-12b0dff1f902"
      },
      "execution_count": 18,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 800x600 with 2 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "query = \"The bowler took three wickets in one over\"\n",
        "\n",
        "query_embedding = model.encode([query])\n",
        "\n",
        "scores = cosine_similarity(query_embedding, embeddings)[0]\n",
        "\n",
        "results = list(zip(sentences, scores))\n",
        "\n",
        "results = sorted(results, key=lambda x: x[1], reverse=True)\n",
        "\n",
        "print(\"Top 2 most similar sentences:\\n\")\n",
        "\n",
        "for sentence, score in results[:2]:\n",
        "    print(sentence, \" --> similarity:\", round(score,3))"
      ],

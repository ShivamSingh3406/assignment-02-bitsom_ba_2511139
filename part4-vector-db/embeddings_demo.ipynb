    {
      "cell_type": "code",
      "source": [
        "from sentence_transformers import SentenceTransformer\n",
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd"
      ],
      "metadata": {
        "id": "oMAwWF1XznTQ"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "sentences = [\n",
        "\n",
        "# Cricket\n",
        "\"The batsman scored a century in the final match.\",\n",
        "\"The bowler delivered a fast yorker to dismiss the player.\",\n",
        "\"The cricket team celebrated their victory after a thrilling game.\",\n",
        "\"The bowler took three wickets in one over.\",\n",
        "\n",
        "# Cooking\n",
        "\"I prepared a delicious pasta with fresh vegetables.\",\n",
        "\"The chef added spices to enhance the flavor of the curry.\",\n",
        "\"Baking a chocolate cake requires precise measurements.\",\n",
        "\n",
        "# Cybersecurity\n",
        "\"Cybersecurity protects systems from digital attacks.\",\n",
        "\"Strong passwords help prevent unauthorized access.\",\n",
        "\"Encryption ensures that sensitive data remains secure.\"\n",
        "\n",
        "]"
      ],
      "metadata": {
        "id": "2yQkE6t1zvJE"
      },
      "execution_count": 15,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "model = SentenceTransformer('all-MiniLM-L6-v2')"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 170,
          "referenced_widgets": [
